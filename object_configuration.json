{
    "PackageManager_PackageDefinition": 
        {
        "FeatureName": 
            {
                "FieldType": "StringInput",
                "Display": "Package Name",
                "PlaceholderText": "Provide Package Name",
                "FieldRole": "DisplayRole",
                "IsMandatory": "True"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "Display": "Package Description",
                "PlaceholderText": "Provide Package Description",
                "FieldRole": "DescriptionRole",
                "IsMandatory": "True"
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "Display": "Definition File Name",
                "DefaultValue": "definition.json",
                "IsForDataExport": "False",
                "FileExtension": "*.json",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Cleaned/%FeatureName%",
                "IsMandatory": "True"
            },
        "Priority":
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 100,
                "MaxValue": 999,
                "DefaultValue": 100,
                "DistributeEvenly": "True",
                "ShowInTreeView": "True"
            },
        "GUID":
            {
                "FieldType": "StringInput",
                "Display": "Definition GUID",
                "FieldRole": "UniqueIdentifier",
                "ShowInEditor": "False"
            },
        "Tasks": 
            {
                "FieldType": "ChildObjectReference",
                "Class": "PackageManager_TaskDefinition",
                "ShowInEditor": "False"
            }

        },
    "PackageManager_TaskDefinition":
        {
        "TaskName": 
            {
                "FieldType": "StringInput",
                "FieldRole": "DisplayRole",
                "ShowInTreeView": "True",
                "IsMandatory": "True"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "FieldRole": "DescriptionRole"
            },
        "Order": 
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 1,
                "MaxValue": 99,
                "DistributeEvenly": "True",
                "ShowInTreeView": "True"
            },
        "TaskType": 
            {
                "FieldType": "FixedInput",
                "Options": {"Transport Package": "Transport", "SQL Script": "SQL", "Schema Extension": "Schema", "Bug Fix Package": "BugFix"},
                "DefaultValue": "Transport",
                "Display": "Task Type",
                "ShowInTreeView": "True",
                "IsMandatory": "True"
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryStatic": "Export",
                "RedirectDirectoryRelativeTo": "Parent",
                "IsMandatory": "True",
                "ShowInTreeView": "True"
            },
        "ExportFile":
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Data/%Parent.FeatureName%/%TaskType%"
            },
        "ExportFileHash": 
            {
                "FieldType": "TextInput",
                "Display": "Transport Checksum"
            },
        "State": 
            {
                "FieldType": "FixedInput",
                "Options": {"Development": "Development", "Testing": "Testing", "Released": "Released"},
                "DefaultValue": "Development",
                "ShowInTreeView": "True"
            },
        "CompilerOption": 
            {
                "FieldType": "FixedInput",
                "Options": {"No Compilation": "None", "Full Compilation": "Full", "Skip Web Projects Compilation":"NoWeb"},
                "DefaultValue": "NoWeb",
                "ShowInTreeView": "True"
            },
        "Environment": 
            {
                "FieldType": "FixedInput",
                "Options": {"Any": "Any", "Development": "DEV", "Test": "TEST", "Production": "PROD"},
                "DefaultValue": "Any",
                "ShowInTreeView": "True"
            },
        "AutoUpdate": 
            {
                "FieldType": "BooleanInput",
                "DefaultValue": "False"
            },
        "TestScript":
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName"
            },
        "Tag":
            {
                "FieldType": "ListInput",
                "Separator": ","
            }
        },
        "ExecutionPlanner_ExecutionGroup": 
            {
            "Name": 
                {
                    "FieldType": "StringInput",
                    "Display": "Group Name",
                    "PlaceholderText": "Provide Group Name",
                    "FieldRole": "DisplayRole"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "ExecutionTasks": 
                {
                    "FieldType": "ChildObjectReference",
                    "Class": "ExecutionPlanner_ExecutionTask",
                    "ShowInEditor": "False"
                }
            },
        "ExecutionPlanner_ExecutionTask": 
            {
            "Name": 
                {
                    "FieldType": "StringInput",
                    "Display": "Group Name",
                    "PlaceholderText": "Provide Group Name",
                    "FieldRole": "DisplayRole"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "TaskName":
                {
                    "FieldType": "StringInput",
                    "Source": "TaskName"
                },
            "TaskType":
                {
                    "FieldType": "StringInput",
                    "Source": "TaskType",
                    "Transporter": ["Transport", "BugFix"],
                    "SQLScript": ["SQL"],
                    "SchemaExtension": ["Schema"]
                },
            "FeatureName":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.FeatureName"
                },
            "ParentDescription":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.Description"
                },
            "Connection":
                {
                    "FieldType": "StringInput"   
                },
            "DefinitionFile":
                {
                    "FieldType": "FileInput",
                    "FileSelectionMode": "Relative"
                },
            "ExportFile":
                {
                    "FieldType": "FileInput",
                    "FileSelectionMode": "Relative"
                }
            },
        "Connection_Configuration": 
            {
            "ConnectionName": 
                {
                    "FieldType": "StringInput",
                    "Display": "Connection Name",
                    "PlaceholderText": "Provide Connection Name",
                    "FieldRole": "DisplayRole",
                    "IsMandatory": "True"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Connection Description",
                    "PlaceholderText": "Connection Description",
                    "FieldRole": "DescriptionRole"
                },
            "ServerAddress":
                {
                    "FieldType": "StringInput",
                    "IsMandatory": "True"
                },
            "DatabaseName":
                {
                    "FieldType": "StringInput",
                    "IsMandatory": "True"
                },
            "SQLUserName":
                {
                    "FieldType": "StringInput",
                    "IsMandatory": "True"
                },
            "SQLPassword":
                {
                    "FieldType": "StringInput",
                    "IsSensitive": "True" ,
                    "IsMandatory": "True"
                },
            "ApplicationUserName":
                {
                    "FieldType": "StringInput",
                    "IsMandatory": "True"
                },
            "ApplicationPassword":
                {
                    "FieldType": "StringInput",
                    "IsSensitive": "True",
                    "IsMandatory": "True"
                },
            "EncryptConnection":
                {
                    "FieldType": "BooleanInput",
                    "DefaultValue": "True"
                },
            "ToolsDirectory":
                {
                    "FieldType": "FileInput",
                    "FileSelectionMode": "DirectoryPath"
                }
            }
}

