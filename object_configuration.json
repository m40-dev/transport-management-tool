{
    "PackageManager_PackageDefinition": 
        {
        "PackageName": 
            {
                "FieldType": "StringInput",
                "Display": "Package Name",
                "PlaceholderText": "Provide Package Name",
                "FieldRole": "DisplayRole",
                "IsMandatory": "True"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "Display": "Package Description",
                "PlaceholderText": "Provide Package Description",
                "FieldRole": "DescriptionRole",
                "IsMandatory": "True"
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "Display": "Definition File Name",
                "DefaultValue": "definition.json",
                "IsForDataExport": "False",
                "FileExtension": "*.json",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Source_Files/%PackageName%",
                "IsMandatory": "True"
            },
        "SortOrder":
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 100,
                "MaxValue": 999,
                "DefaultValue": 100,
                "DistributeEvenly": "True",
                "ShowInTreeView": "True"
            },
        "ChildTasks": 
            {
                "FieldType": "ChildObjectReference",
                "Class": "PackageManager_TaskDefinition",
                "ShowInEditor": "False"
            }

        },
    "PackageManager_TaskDefinition":
        {
        "TaskName": 
            {
                "FieldType": "StringInput",
                "FieldRole": "DisplayRole",
                "ShowInTreeView": "True",
                "IsMandatory": "True"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "FieldRole": "DescriptionRole"
            },
        "SortOrder": 
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 1,
                "MaxValue": 99,
                "DistributeEvenly": "True",
                "ShowInTreeView": "True"
            },
        "TaskType": 
            {
                "FieldType": "FixedInput",
                "Options": {"Transport Package": "Transport", "SQL Script": "SQL", "Schema Extension": "Schema", "Bug Fix Package": "BugFix"},
                "DefaultValue": "Transport",
                "Display": "Task Type",
                "ShowInTreeView": "True",
                "IsMandatory": "True",
                "XMLTemplateTypes": ["Transport", "BugFix"]
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryStatic": "Task_Definitions",
                "RedirectDirectoryRelativeTo": "Parent",
                "IsMandatory": "True",
                "ShowInTreeView": "True"
            },
        "ExportFile":
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Package_Data/%Parent.PackageName%/%TaskType%"
            },
        "CompilerOption": 
            {
                "FieldType": "FixedInput",
                "Options": {"No Compilation": "None", "Full Compilation": "Full", "Skip Web Projects Compilation":"NoWeb"},
                "DefaultValue": "NoWeb",
                "ShowInTreeView": "True"
            },
        "AutoUpdate": 
            {
                "FieldType": "BooleanInput",
                "DefaultValue": "False"
            },
        "Tag": 
            {
                "FieldType": "ListInput",
                "Separator": ","
            }
        },
        "ExecutionPlanner_ExecutionGroup": 
            {
            "GroupName": 
                {
                    "FieldType": "StringInput",
                    "Display": "Group Name",
                    "PlaceholderText": "Provide Group Name",
                    "FieldRole": "DisplayRole"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "ExecutionTasks": 
                {
                    "FieldType": "ChildObjectReference",
                    "Class": "ExecutionPlanner_ExecutionTask",
                    "ShowInEditor": "False"
                }
            },
        "ExecutionPlanner_ExecutionTask": 
            {
            "TaskName": 
                {
                    "FieldType": "StringInput",
                    "Display": "Task Name",
                    "PlaceholderText": "Provide Task Name",
                    "FieldRole": "DisplayRole",
                    "Source": "TaskName"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "TaskType":
                {
                    "FieldType": "StringInput",
                    "Source": "TaskType",
                    "Transporter": ["Transport", "BugFix"],
                    "SQLScript": ["SQL"],
                    "SchemaExtension": ["Schema"],
                    "ShowInTreeView": "True"
                },
            "PackageName":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.PackageName"
                },
            "ParentDescription":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.Description"
                },
            "Connection":
                {
                    "FieldType": "StringInput"   
                },
            "DefinitionFile":
                {
                    "FieldType": "FileInput",
                    "FileSelectionMode": "Relative"
                },
            "ExportFile":
                {
                    "FieldType": "FileInput",
                    "FileSelectionMode": "Relative"
                },
            "CompilerOption": 
                {
                    "FieldType": "FixedInput",
                    "Options": {"No Compilation": "None", "Full Compilation": "Full", "Skip Web Projects Compilation":"NoWeb"},
                    "DefaultValue": "NoWeb",
                    "ShowInTreeView": "True"
                },
            "AutoUpdate":
                {
                    "FieldType": "BooleanInput",
                    "DefaultValue": "False",
                    "ShowInTreeView": "True"
                }
            }
}

