/* Application Defined Color Variables: 


*/

/* Global Widget Configurations */
QMainWindow, QDialog, QWidget, QSplitter, QMessageBox, CustomDialogWindow, CustomMainWindow{
	background-color: @BaseColor;
	border-color: @AltBaseColor;
}

QSplitter::handle{
	border:0px;
	background-color: qlineargradient(x1: 0, x2: 0, y1: 0, y2:1, stop: 0 transparent, stop: 0.5 @BorderColor, stop: 1 transparent);
	margin: 0px;
}

QLabel, QCheckBox, QRadioButton{
	background: transparent;
	color: @TextColor;
}
QCheckBox::hover, QRadioButton::hover{
	color: @HighlightedText;
}

QLineEdit, QComboBox{
	background-color: @AltBaseColor;
	border: 1px solid @BorderColor;
	border-radius: 2px;
	min-height: 1.8em;
	margin: 1px;
	min-width: 10em;
	font-size: 12px;
}
QComboBox::down-arrow{
	padding:0px;
	border: 0px;
	/* background: transparent; */
	image: url("./lib/ui/img/icons/arrow_down_borderless.png");
}
QPlainTextEdit, QTextEdit{
	background-color: @AltBaseColor;
	min-height: 75px;
	border: 1px solid @BorderColor;
}

QLineEdit::selection, QTextEdit::selection, QPlainTextEdit::selection{
	background-color: @HighlightColor;
}

QStatusBar{
	background: @BaseColor;
	color: @DescriptionTextColor;
	font: bold;
}

QSizeGrip{
	background: transparent;
	border: 0;
}

QSizeGrip[Location="NorthWest"]{
	min-height: 20px;
	min-width:20px;
	background: transparent;
	border: 1px transparent;
}

QCheckBox::indicator{
	width: 25px;
	height: 25px;
}


QComboBox:!enabled,
QPushButton:!enabled,
QToolButton:!enabled,
QTextEdit:!enabled,
QPlainTextEdit:!enabled
{
	background-color: @InactiveObjectColor;
}

/* Global Group boxes configurations (In XML Template Editor view mostly) */
QGroupBox{
	font: bold 14px;
	color: @TextColor;
}

QGroupBox::title{
	margin-top:2px;
	margin-bottom:2px;
	padding: 0px;
}

/* Message Box extended log message styling */
.MessageBox-DetailedMessage{
	font-size: 14px;
	font-family: "Courier New";
	color: @TextColor;
}

/* Global ScrollBar Configurations */
QScrollBar::vertical,QScrollBar::horizontal{
	width:12px;
	height:12px;
	border-radius:2px;
	border: 1px solid @BorderColor;
}

QScrollBar::handle:vertical{
	background-color: qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 @AltBaseColor, stop: 1 @BaseColor);
	border:1px solid @AltBaseColor;
	border-radius:2px;
}

QScrollBar::handle:horizontal{
	background-color: qlineargradient(x1: 1, x2: 1, y1: 0, y2:1, stop: 0 @AltBaseColor, stop: 1 @BaseColor);
	border:1px solid @AltBaseColor;
	border-radius:2px;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical,QScrollBar::sub-page:vertical,QScrollBar::add-page:vertical{
	background: transparent;
	width:0px;height:1px;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal,QScrollBar::sub-page:horizontal,QScrollBar::add-page:horizontal{
	background: transparent;
	width:0px;height:1px;
}

/* Application and context menu configurations */
QMenuBar{
	background-color: @AltBaseColor2;
	font-size: 13px;
	border-radius: 3px;
	border-top: 0px solid @AltBorderColor;
	border-left: 2px solid @AltBorderColor;
	border-right: 2px solid @AltBorderColor;
	border-bottom: 0px solid @AltBorderColor;
	color: @AltTextColor;
	min-width: 5em;
	font: bold;
}

QMenuBar::item{
	padding: 3px;
	margin-left: 3px;
	margin-right: 3px;
}

QMenuBar::item:selected{
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
}

QMenu{
	min-width: 15em;
	font-size: 12px;
	min-height: 30px;
	color: @TextColor;
}

QMenu::item{
	padding: 5px;
	min-height: 1.1em;
	min-width: 15em;
	min-height: 22px;
	color: @AltTextColor;
}

QMenu::item:selected{
	background-color: @SelectedObjectColor;
	font: bold;
	color: @HighlightedText;
}

/* Tab Widgets Configuration */
QTabWidget::pane{
	background-color: @BaseColor;
	border: 0;
}

QTabBar{
	border: 0px;
	border-color: @BorderColor;
	margin: 0;
}
QTabBar::tab{
	background-color: qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 @BaseColor, stop: 1 @BaseColor);
	border: 1px solid @BorderColor;
	border-style: outset;
	border-radius: 2px;
	color: @TextColor;
	padding: 0.6em;
	font-size: 12px;
	margin-top:5px;
}

QTabBar::tab:selected{
	background-color: qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 @SelectedObjectColor, stop: 1 @BaseColor);
	border: 1px solid @BorderColor;
	font: bold 13px;
	color: @HighlightedText;
}

QTabBar::tab:top{
	min-width: 12em;
}

QTabBar::tab:left{
	min-width: 1.1em;

}

QTabBar::tab:selected{
	margin-top: 0px;
	border-left: 2px solid @HighlightedText;
}

/* Tree and List Views styling */

QHeaderView:section:horizontal{
	margin-left: 3px;
	padding-left: 8px;
	padding-right: 8px;
	font: 14px;
	text-align: center;
	border-bottom: 2px solid @BorderColor;
	background-color: @AltBaseColor;
	border-style: solid;
	border-left-width: 1px;
	border-left-color: @BorderColor;
	border-right-color: @BorderColor;
    border-right-width: 1px;
	color: @TextColor;
}

QHeaderView:section:first{
	border-style: solid;
	border-left-width: 0px;
}


QTreeWidget, QTreeView, QListView{
	font-size: 13px;
	border: 0px;
	color: @TextColor;
	/* show-decoration-selected: 1; */
}

/* QTreeWidget::indicator, QTreeView::indicator { 
	width: 30px; 
	height: 30px;
} */
QTreeView::branch:open:has-children{
	image: url("./lib/ui/img/icons/arrow_right_down.png");
}
QTreeView::branch:closed:has-children{
	image: url("./lib/ui/img/icons/arrow_right.png");
}

QTreeWidget::item, QListWidget::item, QListView::item, QTreeView::item{
	min-height: 2em;
    color: @TextColor;
	background-color: @BaseColor;
	margin-top: 2px;
}

QTreeWidget::item:alternate, QListWidget::item:alternate, QListView::item:alternate, QTreeView::item:alternate{
	background-color: @AltBaseColor2;
}

QListView::item:hover, QTreeView::item:hover{
	height: 2em;
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
}

QListView::item:selected, QTreeView::item:selected{
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
	margin-left: 3px;
}

/* Global Buttons configuration */
QPushButton{
    background-color: @ButtonColor;
	min-height: 1.5em;
	min-width: 6em;
	border: 1px solid @AltBorderColor;
	border-radius: 2px;
	border-style: outset;
	text-align: center;
    margin: 0px;
    padding: 0px;
	font-size: 12px;
	color:	@AltTextColor;
}

QToolButton{
    background-color:@ButtonColor;
	color:	@AltTextColor;
	margin: 1px;
	border: 1px solid @AltBorderColor;
	border-radius: 2px;
	padding: 3px;
	min-height: 1.3em;
	font-size: 12px;
}

QPushButton:hover, QToolButton:hover{
	background-color: @SelectedObjectColor;
	border: 1px solid @BorderColor;
	color: @AltTextColor;
	font: bold;
}

/* Configuration of the custom sidebar buttons */
QWidget#SideBar{
	border-right: 2px solid @AltBorderColor;
}

QToolButton[ToolButton=SideBar]{
	background: transparent;
	border: none;
	width: 30px;
	height: 30px;
	margin-top: 5px;
}

QToolButton[ToolButton=SideBar]:hover{
	background: @SelectedObjectColor;
}

QToolButton[ToolButton=SideBar]:checked{
	border-left: 3px solid #9da09f;
	background: transparent;
}

QToolButton[ToolButton=DeleteItem]{
	color:#9e2015;
	font: bold;
}

QToolButton[ToolButton=DeleteItem]:hover{
	color:#ffffff;
	background-color: #c5675e;
	border:1px solid #9e2015;
}

QToolButton#PackageManagerButton{
	image: url("./lib/ui/img/icons/PackageManager.png");
}
QToolButton#TemplateEditorButton{
	image: url("./lib/ui/img/icons/XMLTemplateEditor.png");
}
QToolButton#SettingsButton{
	image: url("./lib/ui/img/icons/Settings.png");
}

/* Not in use yet */
QToolButton[Widget=AddButton]{
	background-image: url("./lib/ui/img/add_btn.png");
	border-radius: 16px;
	border: none;
}

QToolButton[Widget=DeleteButton]::hover{
	background-color: #f7b3a3;
}


QToolButton[Widget=SelectFileButton]{
	background-image: url("./lib/ui/img/search_btn.png");
	border-radius: 16px;
	border: none;
}

/* Package Manager Custom widgets configuration */

/* Central widget for any item displayed in the package manager view */

QTreeView[PackageManager="PackageManagerTreeView"]{
	background-color: transparent;
}

QTreeView[PackageManager="PackageManagerTreeView"]::item:hover{
	background-color: transparent;
}

QTreeView::item:selected[PackageManager="PackageManagerTreeView"]{
	background-color: transparent;
}

QWidget[PackageManager="PackageManagerWidget"]{
	background: transparent;
	margin-top: 2px; 
	margin-bottom: 2px;
}

QWidget[PackageManager="PackageManagerIcon"]:hover{
	border: 1px solid @BorderColor;
	background-color: @SelectedObjectColor;
}

/* Inner widget Frame configuration for the Package Definition item objects */
QFrame[PackageManagerWidget="PackageItem"]{
	background-color: @ParentObjectColor;
	border: 1px solid @BorderColor;
}

QFrame[PackageManagerWidget="TaskItem"]{
	background-color: @ChildObjectColor;
	border: 1px solid @BorderColor;
	border-left: 3px solid @BorderColor;
}

QFrame[PackageManagerWidget="PackageItem"]::hover,
QFrame[PackageManagerWidget="TaskItem"]::hover{
	/* background-color: @SelectedObjectColor; */
	background-color: qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 @SelectedObjectColor, stop: 1 transparent);
}

/* Global setting for any object in the unsaved state - this definition always needs to be at the bottom to take effect over other stylesheets */
QWidget[ObjectSaved="False"]{
	border-left: 3px solid rgba(233, 181, 12, 0.575);
}

QWidget[PackageManager="PackageManagerIcon"]{
	min-height: 20px;
	min-width: 20px;
	border: 0px;
	background-color: transparent;
}

/* Execution Planner Custom widgets configuration */
QTreeView#ExecutionPlannerTreeView{

}

QTreeView#ExecutionPlannerTreeView::item{
	background-color: transparent;
}

QTreeView#ExecutionPlannerTreeView::hover{
	background-color: transparent;
}

QWidget[ExecutionPlanner="ExecutionPlannerWidget"]{
	background: transparent;
	margin-top: 2px; 
	margin-bottom: 2px;
	min-height: 1em;
}

QFrame[ExecutionPlannerWidget="ExecutionGroup"]{
	background-color: @ParentObjectColor;
	border: 1px solid @BorderColor;
	border-left: 3px solid @BorderColor;
	
}

QFrame[ExecutionPlannerWidget="ExecutionTask"]{
	/* background: transparent; */
	background-color: @ChildObjectColor;
	border: 1px solid @BorderColor;
	border-left: 3px solid @BorderColor;
}

QFrame[ExecutionPlannerWidget="ExecutionGroup"]::hover,
QFrame[ExecutionPlannerWidget="ExecutionTask"]::hover{
	background-color: qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 @SelectedObjectColor, stop: 1 transparent);
}

/* Start Group button */
QToolButton[ExecutionPlannerWidget="ExecutionGroupAction"]{
	min-height: 10px;
	min-width: 10px;
	border: 0px;
	background-color: transparent;
}

QToolButton[ExecutionPlannerWidget="ExecutionGroupAction"]::hover{
	min-height: 10px;
	min-width: 10px;
	border: 1px solid @BorderColor;
	background-color: @SelectedObjectColor;
}

/* Start task button */
QToolButton[ExecutionPlannerWidget="ExecutionTaskAction"]{
	min-height: 10px;
	min-width: 10px;
	border: 0px;
	background-color: transparent;
}

QToolButton[ExecutionPlannerWidget="ExecutionTaskAction"]::hover{
	border: 1px solid @BorderColor;
	background-color: @SelectedObjectColor;
}

QWidget[ExecutionPlannerWidget="StopExecutionQueue"]{
	min-width: 25px;
	min-height: 25px;
	border: 0px;
	background-color: transparent;
}

QWidget[ExecutionPlannerWidget="StopExecutionQueue"]:hover{
	border: 1px solid #9e2015;
}


/* Execution Planner configuration - Execution states handling for Execution Group widgets (Frames) */

QWidget[GroupExecutionState="Running"]{
	border-left: 3px solid rgba(233, 181, 12, 0.575);
	font: bold;
	color: rgba(233, 181, 12, 0.575);
}

QWidget[GroupExecutionState="Finished"]{
	border-left: 3px solid rgba(6, 117, 6, 0.795);
	font: bold;
	color: rgba(6, 117, 6, 0.795);
}

QWidget[GroupExecutionState="HasErrors"]{
	border-left: 3px solid rgba(165, 37, 15, 0.89);
	font: bold;
	color: rgba(165, 37, 15, 0.89);
}

/* Execution Planner configuration - Execution states handling for execution task wigdets (Frames) */

QWidget[ExecutionState="Running"]{
	border-left: 3px solid rgba(233, 181, 12, 0.575);
	color:  rgba(233, 163, 12, 0.863);
	font: bold;
}

QWidget[ExecutionState="Queued"]{
	border-left: 3px solid rgba(0, 202, 238, 0.918);

	color: rgba(0, 202, 238, 0.918);
	font: bold;
}

QWidget[ExecutionState="Finished"]{
	border-left: 3px solid rgba(6, 117, 6, 0.795);
	font: bold;
	color: rgba(6, 117, 6, 0.795);
}

QWidget[ExecutionState="Finished with Errors"]{
	border-left: 3px solid rgba(165, 37, 15, 0.89);
	font: bold;
	color: rgba(165, 37, 15, 0.89);
}

QWidget[ExecutionState="Terminated"]{
	border-left: 3px solid rgba(165, 37, 15, 0.89);
	font: bold;
	color: rgba(196, 41, 14, 0.89);
}

/* Configure Execution status tracker labels formatting */
QLabel[ExecutionState="Ready"]{
	border-left: 0px;
	font: bold;
}

QLabel[ExecutionState="Queued"]{
	border-left: 0px;
}

QLabel[ExecutionState="Running"]{
	border-left: 0px;
}

QLabel[ExecutionState="Finished"]{
	border-left: 0px;
}

QLabel[ExecutionState="Finished with Errors"]{
	border-left: 0px;
}

QLabel[ExecutionState="Terminated"]{
	border-left: 0px;
}

/* Custom Labels Configurations */

/* Generic label for dynamically added object display name and description in the package manager or execution planner treeview */
QLabel[CustomWidget="ItemLabel"]{
	font-size: 13px;
	color: @TextColor;
	font: bold;
	margin-right: 2em;
}

QLabel[CustomWidget="ItemDescription"]{
	font-size: 11px;
	color: @DescriptionTextColor;
	margin: 1px;
}

/* Generic Label used in the custom treeview items (package view, execution planner view) to set the style of dynamic property names  */
QLabel[Label="PropertyName"]{
	font: bold 12px;
	color: @TextColor;
	margin: 2px;
}

/* Generic Label used in the custom treeview items (package view, execution planner view) to set the style of dynamic property values where it is applicable  */

QLabel[Label="PropertyValue"], QCheckbox[Label="PropertyValue"], QRadioButton[Label="PropertyValue"]{
	color: @TextColor;
	margin: 1px;
	font-size: 12px;
}

/* XML Template Editor Custom Configurations */

/* File Path label seen in the xml template editor above the xml preview browser */
QLabel[Widget="FilePathLabel"]{
	background-color: @AltBaseColor;
	font: bold 15px;
	margin: 0px;
	color: @AltTextColor;
	min-height: 25px;
	border: 1px solid @BorderColor;
}

QToolButton[Widget="CustomToolButton"]{
	min-height: 10px;
	min-width: 10px;
	border: 0px;
	background-color: transparent;
}

QToolButton[Widget="CustomToolButton"]::hover{
	border: 1px solid @AltBorderColor;
	background-color: @SelectedObjectColor;
}

QTabBar[CustomTabWidget="XMLTemplateEditorData"]:tab{
	min-width: 9em;
}

QHeaderView:section:horizontal[Widget="XMLTemplateEditorWidget"]{
}

QHeaderView:section:last[Widget="XMLTemplateEditorWidget"]{
	border-right-width: 0px;
}

QTreeView[Widget="XMLTemplateEditorWidget"]{
}

QTreeView[Widget="XMLTemplateEditorWidget"]:item{
}

QTreeView[Widget="XMLTemplateEditorWidget"]::item:hover{
	font: bold;
	background-color: @SelectedObjectColor;
	padding-left: 2px;
	color: @HighlightedText;
}

QTreeView[Widget="XMLTemplateEditorWidget"]::item:selected{
	font: bold;
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
	padding-left: 6px;
	margin:0;
}


/* Object Properties editor dialog configurations */

/* Global property for any editor widget in the form editor dialog view 
To Customize specific object class, use the [Widget="EditorDialog"] property for the object class to be redefined */

QWidget[Widget="EditorDialog"]{
	margin: 0px;
	margin-left: 0px;
	min-height: 1.3em;
	padding:2px;
}

/* Customize the label where the value template has been defined */
QLabel[EditorDialog="PropertyHasValueTemplate"]{
	border-left: 3px solid #5e9e14;
	color:#5e9e14;
	margin-left: 5px;
}

/* Customize the checkbox that is used to toggle the template activation switch */
QCheckBox[EditorDialog="PropertyHasValueTemplate"]{
	color:#5e9e14;
	font:bold;
	margin-top: 2ex;
}

/* Custom Configuration of the label with the mandatory marker asterisk(*) */
QLabel[PropertyEditor="IsMandatory"]{
	font: bold;
	padding: 0px;
	margin: 0px;
	color: rgba(184, 30, 30, 0.856);
	text-align: center;
}

/* Execution Console styling */
QTextEdit[ExecutionPlanner="ConsoleReader"]{
	background-color: @ExecutionLogBGColor;
	color: @ExecutionLogTextColor;
}
/* Console stylesheet - standard console output */
.execution-log{
	font-size: 14px;
	font-family: "Courier New";
	color: @ExecutionLogTextColor;
	padding: 1px;
	word-wrap: break-word;
	white-space:pre-wrap;
}

/* Console stylesheet - console error output formatting */
.execution-error{
	color: @ExecutionLogErrorText;
	background-color: @ExecutionLogError;
	font: bold;
	padding: 5px;
}

/* Console stylesheet - transport manager messages formatting */
.transport-manager{
	color:@ExecutionLogAltTextColor;
	font: italic;
}

/* Console stylesheet - task initialization table headers formatting */
.task-init-header{
	color: @ExecutionLogInitTextColor;
	text-align: center;
	border-top: 2px solid @ExecutionLogInitTextColor;
	font: bold;
}
.task-init-footer{
	color: @ExecutionLogInitTextColor;
	text-align: center;
	border-bottom: 2px solid @ExecutionLogInitTextColor;
	font: bold;
}

/* Console stylesheet - task information data formatting */
.task-info{
	color: @ExecutionLogAltTextColor;
	text-align: center;
	padding: 2px;
}

/* Console stylesheet - task execution success status formatting */
.task-finished-success{
	text-align: center;
	font: bold;
	color: @ExecutionLogSuccessText;
	background: @ExecutionLogSuccess;
}

/* Console stylesheet - task execution error status formatting */
.task-finished-error{
	text-align: center;
	font: bold;
	color: @ExecutionLogErrorText;
	background-color: @ExecutionLogError;
}

/* Application Settings View */

/* Configuration Sections navigation  */
QHeaderView[SettingsWidget="ConfigurationSectionsTreeView"]::section:horizontal{
	font: bold;
	border-style: solid;
	border-left-width: 0px;
	border-right-width: 0px;
	background-color: @AltBaseColor;
}

QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]{
	font: bold;
	font-size: 14px;
	color: @TextColor;
}

QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]::item{
	font: bold;
	font-size: 14px;
	min-height: 1.8em;
	margin-top: 5px;
	border-left: 0px;
}

QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]::item:hover{
	padding-left: 4px;
	background-color: @AltBaseColor;
	color: @TextColor;
}

QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]::item:selected{
	padding-left: 10px;
	margin: 0px;
	border: 0px;
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
}

QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]::branch:open:has-children{
	image: url("./lib/ui/img/icons/arrow_right_down.png");
}
QTreeView[SettingsWidget="ConfigurationSectionsTreeView"]::branch:closed:has-children{
	image: url("./lib/ui/img/icons/arrow_right.png");
	margin-top: 5px;
}

/* Configuration Editor custom widgets */

/* Header configuration above the list views of the object model configuration editors */
QLabel[ConfigurationEditor="ListViewHeader"]{
	background-color: @AltBaseColor;
	font-size: 15px;
	font: bold;
	color: @TextColor;
}

QListView[ConfigurationEditor="ObjectModelListView"]{
	border: 1px solid @BorderColor;
}

QListView[ConfigurationEditor="ObjectModelListView"]::item{
	padding: 0px;
	border: 1px solid @BorderColor;
}

QListView[ConfigurationEditor="ObjectModelListView"]::item:selected{
	margin-top: 75px;
	margin-bottom: 75px;
}

/* Label that is used as handle to drag widgets in the object model editors */
QWidget[ConfigurationEditor="Handle"]{
	color: @TextColor;
	border: 1px solid @BorderColor;
}

QWidget[ConfigurationEditor="Handle"]::hover{
	background-color :@SelectedObjectColor;
}

/* Custom property for any ObjectModelItemWidget displayed in the main view of object model editor*/

QWidget[ConfigurationEditor="ObjectModelEditorWidget"]{
	margin-top: 4px;
	margin-bottom: 4px;
}

QFrame[ConfigurationEditor="ObjectModelEditorFrame"]{
	background-color: @ChildObjectColor;
	border: 1px solid @BorderColor;
}

/* Configuration of the widget that is currently active and expanded */
QWidget[ConfigurationEditor="Active"]{
	background-color: @BaseColor;
	/* border-radius: 2px; */
	border: 5px solid @SelectedObjectColor;
	padding: 2px;
	margin-left: 15px;
	margin-right: 15px;
	margin-top: 25px;
	margin-bottom: 25px;
}

/* Object model editor frame with extended field properties view (visible when configuration editor is active) */
QGroupBox[ConfigurationEditor="FieldConfigurationFrame"]{
	border-radius: 3px;
	border: 1px solid @BorderColor;
	margin-top:12px;
	margin-left: 1ex;
	margin-right: 1ex;
}

/* Customization of the frame title */
QGroupBox[ConfigurationEditor="FieldConfigurationFrame"]::title{
	subcontrol-origin: margin;
    subcontrol-position: top center; /* position at the top center */
}

/* Horizontal line separator that keeps standard fields separated from dynamic ones */

QFrame[FieldConfigurationFrame="Separator"]{
	border-top: 2px solid qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 transparent, stop: 0.5 #615c51b6, stop: 1 transparent);
}

/* This is entire widget including margins etc, here the list spacing can be configured for the Object model samples and default objects */
QWidget[ConfigurationEditor="ObjectModelSampleWidget"]{
	background: transparent;
	margin-top: 2px;
	margin-bottom: 2px;
}

/* This is the inner widget frame that is rendered on the list as widget */
QFrame[ConfigurationEditor="ObjectModelWidgetFrame"]{
	background-color: @ChildObjectColor;
	border: 1px solid @BorderColor;
}

QFrame[ConfigurationEditor="ObjectModelWidgetFrame"]::hover{
	background-color: @SelectedObjectColor;
}

/* Shared properties of object model editor widgets */

QWidget[ConfigurationEditor="SectionLabel"]{
	font-size: 28px;
	color:@TextColor;
}

QWidget[ConfigurationEditor="SectionDescription"]{
	color: @DescriptionTextColor;
}

QWidget[ConfigurationEditor="ParameterGroupHeader"]{
	font: 18px;
	color:@TextColor;
}
QWidget[ConfigurationEditor="ParameterGroupDescription"]{
	color: @DescriptionTextColor;
}

QWidget[ConfigurationEditor="ParameterName"]{
	font: 14px;
	color:@TextColor;
}
QWidget[ConfigurationEditor="ParameterDescription"]{
	color: @DescriptionTextColor;
	font: 12px;
}

QWidget[ConfigurationEditor="ParameterGroupSeparator"]{
	border-top: 2px solid qlineargradient(x1: 0, x2: 1, y1: 0, y2:0, stop: 0 transparent, stop: 0.5 @BorderColor, stop: 1 transparent);
}

QWidget[ConfigurationEditor="PropertyLabel"]{
	color:@TextColor;
	text-align: right;
	margin:1px;
	font-size: 12px;
}

QWidget[ConfigurationEditor="PropertyDescription"]{
	color: @DescriptionTextColor;
	margin:1px;
	font-size: 12px;
}

QWidget[ConfigurationEditor="PropertyEditor"]{
}

QWidget[ConfigurationEditor="FieldLabel"]{
	color:@TextColor;
	font: bold;
	font-size: 14px;
	margin: 1px;
}

QWidget[ConfigurationEditor="FieldDescription"]{
	color:@DescriptionTextColor;
	margin: 1px;
	padding-left: 5px;
	font-size: 12px;
}

/* Custom button configuration that lets the editor to pop out to a window for bigger view */
QToolButton[ConfigurationEditor="MaximizePropertyEditor"]{
	min-height: 1px;
	min-width: 1px;
	height: 5px;
	width: 5px;
	border: 1px solid @BorderColor;
}

/* CustomWindowDecoration  Configuration*/

QWidget[CustomWindowDecoration="ManagedWindow"]{
	border: 1px solid @BorderColor;
	border-radius: 5px;
}

QFrame#WindowTitleDecoration{
	background-color: @AltBaseColor;
	/* border: 1px solid @AltBaseColor; */
	min-height: 32px;
	border-color: transparent;
	border-width: 1px;
	border-bottom: 2px solid @AltBorderColor;
	border-top-right-radius: 5px;
	border-top-left-radius: 5px;
}

QLabel[CustomWindowDecoration="WindowIcon"]{
	margin-left: 5px;
	min-height: 15px;
	min-width: 15px;
	height: 18px;
 	width: 18px;
}

QLabel[CustomWindowDecoration="WindowTitle"]{
	font: bold 13px;
	background-color: transparent;
	text-align: center;
	margin-left: 10px;
}

QToolButton[CustomWindowDecoration="MinimizeActionButton"],
QToolButton[CustomWindowDecoration="MaximizeActionButton"],
QToolButton[CustomWindowDecoration="RestoreActionButton"],
QToolButton[CustomWindowDecoration="CloseActionButton"]{
 background-color: transparent;
 border: none;
 margin: 0px;
 /* margin-bottom:2px; */
 min-width: 25;
 min-height: 25px;
 height: 25px;
 width: 25px;
}

QToolButton[CustomWindowDecoration="MinimizeActionButton"]::hover,
QToolButton[CustomWindowDecoration="MaximizeActionButton"]::hover,
QToolButton[CustomWindowDecoration="RestoreActionButton"]{
	background-color: @SelectedObjectColor;
	color: @HighlightedText;
}

QToolButton[CustomWindowDecoration="CloseActionButton"]::hover{
	background-color: rgba(170,0,0,150);
}

CustomDialogWindow{
	/* background-color: #c9c9c9; */
	border: 1px solid #9e2015;
	border-radius: 5px;
}

CustomMainWindow{
	/* background-color: @BaseColor; */
	border: 1px solid #9e2015;
	border-radius: 5px;
}