{
    "PackageManager_PackageDefinition": 
        {
        "FeatureName": 
            {
                "FieldType": "StringInput",
                "Display": "Package Name",
                "PlaceholderText": "Provide Package Name",
                "FieldRole": "DisplayRole",
                "isMandatory": "True"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "Display": "Package Description",
                "PlaceholderText": "Provide Package Description",
                "FieldRole": "DescriptionRole"
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "Display": "Definition File Name",
                "DefaultValue": "definition.json",
                "IsForDataExport": "False",
                "FileExtension": "*.json",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Cleaned/%FeatureName%"
            },
        "Priority":
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 100,
                "MaxValue": 999,
                "DefaultValue": 100,
                "DistributeEvenly": "True"
            },
        "GUID":
            {
                "FieldType": "StringInput",
                "Display": "Definition GUID",
                "FieldRole": "UniqueIdentifier",
                "ShowInEditor": "False"
            },
        "Tasks": 
            {
                "FieldType": "ChildObjectReference",
                "Class": "PackageManager_TaskDefinition",
                "ShowInEditor": "False"
            }

        },
    "PackageManager_TaskDefinition":
        {
        "TaskName": 
            {
                "FieldType": "StringInput",
                "FieldRole": "DisplayRole"
            },
        "Description": 
            {
                "FieldType": "TextInput",
                "FieldRole": "DescriptionRole"
            },
        "Order": 
            {
                "FieldType": "IntegerInput",
                "FieldRole": "SortOrder",
                "MinValue": 1,
                "MaxValue": 99,
                "DistributeEvenly": "True"
            },
        "TaskType": 
            {
                "FieldType": "FixedInput",
                "Options": {"Transport Package": "Transport", "SQL Script": "SQL"},
                "DefaultValue": "Transport",
                "Display": "Task Type"
            },
        "DefinitionFile": 
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryStatic": "Export",
                "RedirectDirectoryRelativeTo": "Parent"
            },
        "ExportFile":
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName",
                "RedirectDirectoryDynamic": "Data/%Parent.FeatureName%/%TaskType%"
            },
        "ExportFileHash": 
            {
                "FieldType": "TextInput",
                "Display": "Transport Checksum"
            },
        "State": 
            {
                "FieldType": "FixedInput",
                "Options": {"Development": "Development", "Testing": "Testing", "Released": "Released"},
                "DefaultValue": "Development"
            },
        "CompilerOption": 
            {
                "FieldType": "FixedInput",
                "Options": {"No Compilation": "NONE", "Full Compilation": "FULL", "Skip Web Projects Compilation":"NOWEB"},
                "DefaultValue": "NOWEB"
            },
        "Environment": 
            {
                "FieldType": "FixedInput",
                "Options": {"Any": "Any", "Development": "DEV", "Test": "TEST", "Production": "PROD"},
                "DefaultValue": "Any"
            },
        "AutoUpdate": 
            {
                "FieldType": "BooleanInput",
                "DefaultValue": "False"
            },
        "TestScript":
            {
                "FieldType": "FileInput",
                "FileSelectionMode": "FileName"
            },
        "Tag":
            {
                "FieldType": "ListInput",
                "Separator": ","
            }
        },
        "ExecutionPlanner_ExecutionGroup": 
            {
            "Name": 
                {
                    "FieldType": "StringInput",
                    "Display": "Group Name",
                    "PlaceholderText": "Provide Group Name",
                    "FieldRole": "DisplayRole"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "ExecutionTasks": 
                {
                    "FieldType": "ChildObjectReference",
                    "Class": "ExecutionPlanner_ExecutionTask",
                    "ShowInEditor": "False"
                }
            },
        "ExecutionPlanner_ExecutionTask": 
            {
            "Name": 
                {
                    "FieldType": "StringInput",
                    "Display": "Group Name",
                    "PlaceholderText": "Provide Group Name",
                    "FieldRole": "DisplayRole"
                },
            "Description": 
                {
                    "FieldType": "TextInput",
                    "Display": "Package Description",
                    "PlaceholderText": "Provide Package Description",
                    "FieldRole": "DescriptionRole"
                },
            "TaskName":
                {
                    "FieldType": "StringInput",
                    "Source": "TaskName"
                },
            "FeatureName":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.FeatureName"
                },
            "ParentDescription":
                {
                    "FieldType": "StringInput",
                    "Source": "PARENT_DEF.Description"
                }
            }
}

